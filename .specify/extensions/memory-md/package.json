{
  "name": "speckit-memory",
  "version": "1.0.1",
  "private": true,
  "description": "Local memory database optimizer and MCP server for Spec Kit Memory Hub.",
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "speckit-memory": "dist/bin/speckit-memory.js"
  },
  "scripts": {
    "build": "npx -y esbuild bin/speckit-memory.ts \"src/**/*.ts\" --platform=node --target=node18 --format=cjs --outdir=dist --outbase=.",
    "postbuild": "chmod +x dist/bin/speckit-memory.js",
    "clean": "rm -rf dist",
    "start": "node dist/bin/speckit-memory.js",
    "migrate": "node dist/bin/speckit-memory.js migrate-memory",
    "test-root": "./scripts/test-root-resolution.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@dqbd/tiktoken": "^1.0.22",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.0",
    "typescript": "^6.0.3",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.13.10"
  }
}
