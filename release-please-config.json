{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",

  "separate-pull-requests": false,

  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,

  "//release-as": "ONE-SHOT for the first release: from a 0.0.0 manifest, breaking changes would otherwise force 1.0.0 (the initial-transition rule that bump-minor-pre-major does not govern). Pin the first cut to 0.1.0 so we stay pre-1.0. REMOVE this `release-as` after 0.1.0 is released so normal bump-minor-pre-major logic resumes.",
  "release-as": "0.1.0",

  "packages": {
    "crates/prompting-press-core": {
      "release-type": "rust",
      "component": "prompting-press-core",
      "package-name": "prompting-press-core",
      "changelog-path": "CHANGELOG.md"
    },
    "crates/prompting-press": {
      "release-type": "rust",
      "component": "prompting-press",
      "package-name": "prompting-press",
      "changelog-path": "CHANGELOG.md"
    },
    "crates/prompting-press-py": {
      "release-type": "rust",
      "component": "prompting-press-py-crate",
      "package-name": "prompting-press-py",
      "changelog-path": "CHANGELOG.md"
    },
    "crates/prompting-press-node": {
      "release-type": "rust",
      "component": "prompting-press-node-crate",
      "package-name": "prompting-press-node",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/python": {
      "release-type": "python",
      "component": "prompting-press-py",
      "package-name": "prompting-press",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/typescript": {
      "release-type": "node",
      "component": "prompting-press-ts",
      "package-name": "prompting-press",
      "changelog-path": "CHANGELOG.md"
    }
  },

  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "prompting-press",
      "components": [
        "prompting-press-core",
        "prompting-press",
        "prompting-press-py-crate",
        "prompting-press-node-crate",
        "prompting-press-py",
        "prompting-press-ts"
      ]
    }
  ]
}
