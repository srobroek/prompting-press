{
  // Minimal strict TS config for the Prompting Press Node wrapper skeleton.
  // Logic-free in spec 001: this exists so `tsc` can later type-check the thin
  // wrapper and emit `.d.ts` declarations alongside the napi-generated binding.
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],

    // Type safety: strict everything.
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,

    // Declaration emit (the facade publishes `.d.ts` types for consumers).
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    // Pin the emit root to `src/` so the facade compiles to `dist/index.js` (not
    // `dist/src/index.js`). The napi-generated `../index.d.ts` is imported by the facade for types
    // only; it lives outside `rootDir` (it is the low-level addon, emitted by napi, not by tsc).
    "rootDir": "./src",

    // Interop / module hygiene.
    "esModuleInterop": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  // The facade source (`src/index.ts`, spec 005) and the code-generated prompt-definition shape
  // under `src/generated/` (constitution C-07, FR-016). `tsc` compiles `src/index.ts` →
  // `dist/index.js` (+ `.d.ts`) and type-checks the generated shape (the US4 freshness-gate proof).
  // The napi-generated `../index.d.ts` (the low-level addon) is pulled in only as an import
  // dependency for type resolution — it is emitted by napi, never by tsc. Tests live in `test/` and
  // run against the built JS (node --test), so they are excluded from the facade compile.
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "test"]
}
