{
  "name": "prompting-press",
  "version": "0.0.0",
  "description": "Node.js distribution of Prompting Press — a typed, variant-aware prompt-template library. A thin Zod facade over the Rust napi-rs binding crate (crates/prompting-press-node) and the shared Rust engine.",
  "license": "Apache-2.0",
  "type": "module",
  "author": "Sjors Robroek",
  "repository": {
    "type": "git",
    "url": "https://github.com/srobroek/prompting-press.git",
    "directory": "packages/typescript"
  },
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "napi": {
    "binaryName": "prompting-press",
    "packageName": "prompting-press"
  },
  "scripts": {
    "build": "pnpm run build:addon && pnpm run build:facade",
    "build:addon": "napi build --release --platform --esm --manifest-path ../../crates/prompting-press-node/Cargo.toml --output-dir .",
    "build:addon:debug": "napi build --platform --esm --manifest-path ../../crates/prompting-press-node/Cargo.toml --output-dir .",
    "build:facade": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "codegen": "node ./scripts/codegen.mjs",
    "pretest": "pnpm run build:facade",
    "test": "node --test \"test/*.test.mjs\"",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.7.2",
    "json-schema-to-typescript": "15.0.4",
    "prettier": "3.8.4",
    "typescript": "5.9.2"
  }
}
