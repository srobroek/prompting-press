{
  "name": "agreement-nested",
  "role": "user",
  "body": "{{ greeting }}, {{ user.name }}",
  "variables": {
    "greeting": {
      "type": "string",
      "origin": "trusted",
      "description": "The greeting word."
    },
    "user": {
      "type": "object",
      "origin": "trusted",
      "description": "The user object whose name is interpolated."
    }
  }
}
