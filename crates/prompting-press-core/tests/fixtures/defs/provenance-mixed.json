{
  "name": "provenance-mixed",
  "role": "user",
  "body": "Question: {{ q }}\nContext: {{ ctx }}\nSystem note: {{ sys }}",
  "variables": {
    "q": {
      "type": "string",
      "origin": "untrusted",
      "description": "The user's untrusted question."
    },
    "ctx": {
      "type": "string",
      "origin": "external",
      "description": "Externally-sourced context."
    },
    "sys": {
      "type": "string",
      "origin": "trusted",
      "description": "Trusted system-supplied note."
    }
  }
}
