{
  "name": "provenance-mixed",
  "role": "user",
  "body": "Question: {{ q }}\nContext: {{ ctx }}\nSystem note: {{ sys }}",
  "variables": {
    "q": {
      "type": "string",
      "trusted": false,
      "description": "The user's untrusted question."
    },
    "ctx": {
      "type": "string",
      "trusted": false,
      "description": "Externally-sourced context (also untrusted)."
    },
    "sys": {
      "type": "string",
      "trusted": true,
      "description": "Trusted system-supplied note."
    }
  }
}
